diff --git a/mm/memory.c b/mm/memory.c
index fb7b8dc75..9a9e61ab5 100644
--- a/mm/memory.c
+++ b/mm/memory.c
@@ -76,6 +76,7 @@
 #include <linux/ptrace.h>
 #include <linux/vmalloc.h>

 	} while (vma);
 }
 
-void pmd_install(struct mm_struct *mm, pmd_t *pmd, pgtable_t *pte)
+void ept_invalidate(struct mm_struct *mm, unsigned long address)
 {
-	spinlock_t *ptl = pmd_lock(mm, pmd);
 
-	if (likely(pmd_none(*pmd))) {	/* Has another populated it ? */
+	struct vm_area_struct *vma;
+	unsigned long vpn, ept_fault_addr, ept_page_addr;
+
+	if (!mm)
+		return;
+
+	vma = READ_ONCE(mm->ept_vma);
+	if (!vma)
+		return;
+
+	/* Compute EPT virtual address */
+	vpn = address >> PAGE_SHIFT;
+	ept_fault_addr = vma->vm_start + vpn * sizeof(unsigned long);
+
+	if (ept_fault_addr < vma->vm_start || ept_fault_addr >= vma->vm_end)
+		return;
+
+	ept_page_addr = ept_fault_addr & PAGE_MASK;
+
+	/* Avoid deadlock */
+	if (!mmap_read_trylock(mm))
+		return;
+
+	/* Re-check after lock */
+	vma = READ_ONCE(mm->ept_vma);
+	if (!vma)
+		goto unlock;
+
+	/* Unmap the EPT metadata page */
+	zap_vma_ptes(vma, ept_page_addr, PAGE_SIZE);
+
+unlock:
+	mmap_read_unlock(mm);
+}
+EXPORT_SYMBOL_GPL(ept_invalidate);
+
+
+
+bool pmd_install(struct mm_struct *mm,
+		pmd_t *pmd,
+		pgtable_t *pte,
+		unsigned long address)
+{
+	spinlock_t *ptl;
+	bool installed = false;
+
+	ptl = pmd_lock(mm, pmd);
+
+	if (likely(pmd_none(*pmd))) {
 		mm_inc_nr_ptes(mm);
-		/*
-		 * Ensure all pte setup (eg. pte page lock and page clearing) are
-		 * visible before the pte is made visible to other CPUs by being
-		 * put into page tables.
-		 *
-		 * The other side of the story is the pointer chasing in the page
-		 * table walking code (when walking the page table without locking;
-		 * ie. most of the time). Fortunately, these data accesses consist
-		 * of a chain of data-dependent loads, meaning most CPUs (alpha
-		 * being the notable exception) will already guarantee loads are
-		 * seen in-order. See the alpha page table accessors for the
-		 * smp_rmb() barriers in page table walking code.
-		 */
-		smp_wmb(); /* Could be smp_wmb__xxx(before|after)_spin_lock */
+		smp_wmb();
 		pmd_populate(mm, pmd, *pte);
 		*pte = NULL;
+		installed = true;
 	}
+
 	spin_unlock(ptl);
+
+	/*
+	 * Call ept_invalidate AFTER releasing the spinlock.
+	 * It's safe to call even if no EPT mapping exists - it will just return.
+	 */
+	if (installed)
+		ept_invalidate(mm, address);
+
+	return installed;
 }
 
-int __pte_alloc(struct mm_struct *mm, pmd_t *pmd)
+
+int __pte_alloc(struct mm_struct *mm,
+		       pmd_t *pmd,
+		       unsigned long address)
 {
 	pgtable_t new = pte_alloc_one(mm);
 	if (!new)
 		return -ENOMEM;
 
-	pmd_install(mm, pmd, &new);
-	if (new)
+	if (!pmd_install(mm, pmd, &new, address))
 		pte_free(mm, new);
+
 	return 0;
 }
 
@@ -2211,7 +2260,7 @@ static int insert_pages(struct vm_area_struct *vma, unsigned long addr,
 
 	/* Allocate the PTE if necessary; takes PMD lock once only. */
 	ret = -ENOMEM;
-	if (pte_alloc(mm, pmd))
+	if (pte_alloc(mm, pmd, addr))
 		goto out;
 
 	while (pages_to_write_in_pmd) {
@@ -4856,7 +4905,7 @@ static vm_fault_t do_anonymous_page(struct vm_fault *vmf)
 	 * Use pte_alloc() instead of pte_alloc_map(), so that OOM can
 	 * be distinguished from a transient failure of pte_offset_map().
 	 */
-	if (pte_alloc(vma->vm_mm, vmf->pmd))
+	if (pte_alloc(vma->vm_mm, vmf->pmd, vmf->address))
 		return VM_FAULT_OOM;
 
 	/* Use the zero-page for reads */
@@ -5214,8 +5263,8 @@ vm_fault_t finish_fault(struct vm_fault *vmf)
 		}
 
 		if (vmf->prealloc_pte)
-			pmd_install(vma->vm_mm, vmf->pmd, &vmf->prealloc_pte);
-		else if (unlikely(pte_alloc(vma->vm_mm, vmf->pmd)))
+			pmd_install(vma->vm_mm, vmf->pmd, &vmf->prealloc_pte, vmf->address);
+		else if (unlikely(pte_alloc(vma->vm_mm, vmf->pmd, vmf->address)))
 			return VM_FAULT_OOM;
 	}
 
